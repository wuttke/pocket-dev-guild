    "/conversations/{conversation_id}/events": {
      "get": {
        "tags": [
          "conversations"
        ],
        "summary": "SSE stream of conversation state changes",
        "description": "Push the full conversation snapshot on every change.\n\nEmits an initial `snapshot` event, then an `update` event each time\nthe underlying record is mutated (new turn appended, busy flag\ntoggles, session_id resolved, summary refreshed). The payload always\ncarries the entire `ConversationInfo` plus a top-level `busy` flag \u2014\nthe UI diffs against its local copy to figure out what changed.",
        "operationId": "stream_conversation_events_conversations__conversation_id__events_get",
        "parameters": [
          {
            "name": "conversation_id",
            "in": "path",
            "required": true,
